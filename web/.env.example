# Telegram
TELEGRAM_BOT_TOKEN=
# Bot webhook: https://api.telegram.org/bot<TOKEN>/setWebhook?url=<NEXT_PUBLIC_APP_URL>/api/telegram/webhook
# Botga "admin5555" yozilganda statistika + admin panel havolasi (o'zgartirish: TELEGRAM_ADMIN_PHRASE)
# TELEGRAM_ADMIN_PHRASE=admin5555

# Session (min 32 chars)
SESSION_SECRET=

# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# App URL (OAuth / redirects)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# OpenAI (AI chat)
OPENAI_API_KEY=

# Usta buyurtma qabuli (so‘m, maydon nomi bilan bir xil birlik)
# ORDER_ACCEPT_FEE_CENTS=10000
# FREE_ORDER_ACCEPTS=3

